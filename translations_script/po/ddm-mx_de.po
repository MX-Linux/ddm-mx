msgstr "Nvidia-Entwicklerpaketquellen anbieten"

#: ../ddm-mx:288
msgid "Implies -f nvidia-driver"
msgstr "Beinhaltet -f nvidia-driver"

#: ../ddm-mx:290
msgid "Create 20-nvidia.conf"
msgstr "20-nvidia.conf erstellen"

