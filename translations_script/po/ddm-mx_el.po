msgstr "Θέλετε να ελέγξετε για νεότερη έκδοση στο αποθετήριο MX Test;"

#: ../ddm-mx:749 ../ddm-mx:750
#, sh-format
msgid "Would you like to check the Nvidia developer repo for a later version?"
msgstr "Θέλετε να ελέγξετε για νεότερη έκδοση στο αποθετήριο Nvidia;"

#. a choice of driver versions is being offerred
#: ../ddm-mx:768 ../ddm-mx:802
#, sh-format
msgid "Which driver do you wish to install"
msgstr "Το πρόγραμμα οδήγησης που θέλετε να εγκαταστήσετε"

#: ../ddm-mx:770
#, sh-format
msgid "Main repos or debian-backports?"
msgstr "Βασικό αποθετήριο ή debian-backports;"

#: ../ddm-mx:772 ../ddm-mx:806
#, sh-format
msgid "Main"
msgstr "Βασικό"

#: ../ddm-mx:776 ../ddm-mx:810
#, sh-format
msgid "Exit"
msgstr "Έξοδος"

#: ../ddm-mx:804
#, sh-format
msgid "Main repos or MX Test"
msgstr "Βασικό αποθετήριο ή MX Test"

#: ../ddm-mx:808
#, sh-format
msgid "MX Test"
msgstr "MX Test"

#: ../ddm-mx:846 ../ddm-mx:1368
#, sh-format
msgid "Candidate is: "
msgstr "Υποψήφιο: "

#. installed version, if any
#: ../ddm-mx:847 ../ddm-mx:1166 ../ddm-mx:1176 ../ddm-mx:1185
#, sh-format
