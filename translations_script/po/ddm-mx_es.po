#: ../ddm-mx:954
#, sh-format
msgid ""
"Please remove with  <sudo nvidia-install --uninstall> and reboot if you wish"
" to proceed"
msgstr ""
"Favor remover con <sudo nvidia-install --uninstall> y reiniciar si desea "
"proceder"

