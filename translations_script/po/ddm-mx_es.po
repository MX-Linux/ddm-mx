#, sh-format
msgid "Possible previous install detected."
msgstr "Detectada posible instalación anterior."

#. possible hybrid graphics detected
#: ../ddm-mx:977
#, sh-format
msgid "nvidia-optimus detected"
msgstr "se detectó nvidia-optimus"

#. ask if this system has hybrid graphics
#: ../ddm-mx:981
#, sh-format
msgid ""
"Answer the next question NO if you are using your Optimus Nvidia card in "
"discrete mode"
msgstr ""
"Responda NO a la siguiente pregunta si está utilizando su tarjeta Optimus "
"Nvidia en modo discreto"

